{
  "name": "@uecsio/nestjs-crud-module",
  "version": "1.2.1",
  "description": "Dynamic CRUD module for NestJS with TypeORM, based on @dataui/crud",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "npm run typecheck && npm run format:check",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "nestjs",
    "crud",
    "typeorm",
    "rest",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@dataui/crud": "^5.0.0",
    "@dataui/crud-typeorm": "^5.0.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@dataui/crud": "^5.0.0",
    "@dataui/crud-typeorm": "^5.0.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.0.1",
    "@nestjs/testing": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "better-sqlite3": "^12.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "jest": "^30.2.0",
    "prettier": "3.8.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.1.0",
    "typeorm": "^0.3.26",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}